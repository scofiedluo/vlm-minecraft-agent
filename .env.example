# =========================
# Python 规划层（必填/建议）
# =========================

# 阿里云百炼 DashScope API Key，不要提交真实密钥
DASHSCOPE_API_KEY=sk-your-api-key

# 视觉模型配置键；具体模型名、调用 URL、max_tokens、temperature、enable_thinking 见 config/model_configs.json
VLM_MODEL=qwen3-vl-flash
# 可选：自定义模型配置文件路径
MODEL_CONFIG_FILE=config/model_configs.json

# Agent 长期目标：会写入 prompt，模型每一步会在保证安全的前提下推进该目标
AGENT_OBJECTIVE=收集木头并保证生存

# 动作模式：dry-run 只打印动作；pyautogui 会真实控制键鼠
ACTION_MODE=dry-run

# 截图区域：留空表示全屏；格式 left,top,width,height，例如 0,0,1280,760
CAPTURE_REGION=

# Agent 循环配置
LOOP_INTERVAL=2.0
MAX_STEPS=5
SCREENSHOT_DIR=runs/screenshots
LOG_DIR=runs/logs

# 技能服务（Python -> Node）
SKILL_SERVER_URL=http://127.0.0.1:3000
SKILL_TIMEOUT_MS=30000
PLANNER_FAIL_RETRY_THRESHOLD=2


# =========================
# Node 执行层（Minecraft / mineflayer）
# =========================

# Minecraft 服务端地址
MC_HOST=localhost
MC_PORT=25565
MC_VERSION=1.20.1

# Bot 用户名（建议与客户端账号不同，避免互踢）
MC_USERNAME=vlm_agent_bot_01

# 技能服务监听地址
SKILL_SERVER_HOST=127.0.0.1
SKILL_SERVER_PORT=3000

# prismarine-viewer（可选，调试观察）
BOT_VIEWER_ENABLED=false
BOT_VIEWER_PORT=3007
BOT_VIEWER_FIRST_PERSON=true
